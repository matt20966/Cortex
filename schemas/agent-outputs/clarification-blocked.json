{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cortex.local/schemas/agent-outputs/clarification-blocked.json",
  "type": "object",
  "required": ["status", "questions"],
  "additionalProperties": true,
  "properties": {
    "status": { "type": "string", "enum": ["blocked"] },
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "question"],
        "properties": {
          "id": { "type": "number" },
          "question": { "type": "string", "minLength": 1 }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
