{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cortex.local/schemas/dashboard.json",
  "title": "Dashboard State",
  "type": "object",
  "required": ["theme", "dailyNotes", "projects", "skills", "tasks"],
  "additionalProperties": true,
  "properties": {
    "theme": { "type": "string" },
    "dailyNotes": { "type": "object" },
    "projects": { "type": "array" },
    "skills": { "type": "array" },
    "tasks": { "type": "array" },
    "navUsage": { "type": "object" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
